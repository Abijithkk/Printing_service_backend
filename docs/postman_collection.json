    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin@qnl.com",
      "type": "string"
    },
    {
      "key": "admin_password",
      "value": "Aa1234567",
      "type": "string"
    },
    {
      "key": "navId",
      "value": "",
      "type": "string"
    },
    {
      "key": "highlightId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
